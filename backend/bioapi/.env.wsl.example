# Copy to .env.wsl when running backend in WSL:
#   cp backend/bioapi/.env.wsl.example backend/bioapi/.env.wsl

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
SEQWB_ALLOW_NON_LOOPBACK=0

# IMPORTANT:
# - When backend runs in WSL, these paths must be Linux paths.
# - Use /home/<user>/... or /mnt/c/... style paths, not C:\... style.

# Optional: BLAST+ binary directory (if blastn is not in PATH)
BLAST_BIN_DIR=

# Optional: folder that contains your user-made BLAST databases
BLASTDB_DIR=

# Optional: primer3_core absolute path (if not in PATH)
PRIMER3_CORE=
